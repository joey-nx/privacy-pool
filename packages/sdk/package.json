{
  "name": "@latent/sdk",
  "version": "0.1.0",
  "description": "Latent Privacy Pool SDK — client-side ZK proving with MetaMask",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "copy-circuit": "bash scripts/copy-circuit.sh"
  },
  "dependencies": {
    "@aztec/bb.js": "3.0.0-nightly.20260102",
    "@noble/curves": "^1.8.0",
    "@noir-lang/noir_js": "1.0.0-beta.18",
    "ethers": "^6.0.0"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "ethers": "^6.0.0"
  }
}
